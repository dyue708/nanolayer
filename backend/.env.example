# ============================================
# 服务器配置
# ============================================
PORT=3000
FRONTEND_URL=http://localhost:5173

# ============================================
# 数据库配置
# ============================================
# 数据库类型：sqlite 或 postgres
# 默认使用 sqlite，无需额外配置
DB_TYPE=sqlite

# PostgreSQL 配置（当 DB_TYPE=postgres 时使用）
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nanolayer
DB_USER=postgres
DB_PASSWORD=your_password
DB_SSL=false

# ============================================
# Fal AI 平台配置
# ============================================
FAL_KEY=your_fal_api_key

# ============================================
# Google Vertex AI 配置（可选，用于直接调用 Vertex 源）
# 支持的模型：fal-ai/nano-banana、fal-ai/nano-banana-pro、fal-ai/nano-banana-2
# ============================================
# GCP 项目 ID（必填，启用 Vertex 时）
VERTEX_AI_PROJECT=your-gcp-project-id
# Vertex AI 区域（默认 us-east5，支持图像生成的区域）
VERTEX_AI_LOCATION=us-east5
# 服务账号 JSON 文件路径（本地开发用）；生产环境建议使用 Workload Identity
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# VERTEX_KEY_PATH=/path/to/service-account.json

# Vertex 模型映射（可选覆盖，默认均使用 gemini-2.0-flash-preview-image-generation）
# VERTEX_MODEL_NANO_BANANA=gemini-2.0-flash-preview-image-generation
# VERTEX_MODEL_NANO_BANANA_PRO=gemini-2.0-flash-preview-image-generation
# VERTEX_MODEL_NANO_BANANA_2=gemini-2.0-flash-preview-image-generation

# ============================================
# 阿里云 OSS 配置
# ============================================
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=your_bucket_name

# ============================================
# 成本配置（每张图片的成本，单位：美元）
# ============================================
COST_NANO_BANANA=0.0396
COST_NANO_BANANA_PRO=0.134
COST_NANO_BANANA_EDIT=0.0396
COST_NANO_BANANA_PRO_EDIT=0.134
# Vertex 源成本（可选，默认值已内置）
# COST_VERTEX_NANO_BANANA=0.03
# COST_VERTEX_NANO_BANANA_EDIT=0.03
# COST_VERTEX_NANO_BANANA_PRO=0.05
# COST_VERTEX_NANO_BANANA_PRO_EDIT=0.05
# COST_VERTEX_NANO_BANANA_2=0.04
# COST_VERTEX_NANO_BANANA_2_EDIT=0.04

# ============================================
# 飞书认证配置（可选，预留）
# ============================================
# FEISHU_APP_ID=your_feishu_app_id
# FEISHU_APP_SECRET=your_feishu_app_secret
# JWT_SECRET=your_jwt_secret